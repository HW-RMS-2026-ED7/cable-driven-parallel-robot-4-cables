
<mujoco model="4_cable_robot">
    <compiler angle="radian"/>

    <option gravity="0 0 -9.81" density="1.2" viscosity="0.05"/>

    <default>
        <tendon width="0.005" rgba="1 1 1 1" damping="2.0"/>
        <motor ctrllimited="false"/>
    </default>

    <worldbody>
        <light pos="0 0 5" dir="0 0 -1" diffuse="0.8 0.8 0.8"/>
        <geom type="plane" size="3 3 0.1" rgba="0.2 0.2 0.2 1"/>

        <site name="anchor_0" pos="1.0 1.0 2.0" size="0.02" rgba="1 0 0 1"/>
        <site name="anchor_1" pos="-1.0 1.0 2.0" size="0.02" rgba="1 0 0 1"/>
        <site name="anchor_2" pos="-1.0 -1.0 2.0" size="0.02" rgba="1 0 0 1"/>
        <site name="anchor_3" pos="1.0 -1.0 2.0" size="0.02" rgba="1 0 0 1"/>

        <body name="end_effector" pos="0 0 1.0">
            <freejoint/>
            <geom type="box" size="0.1 0.1 0.005" mass="1.0" rgba="0 0 1 1"/>

            <site name="platform_0" pos="0.1 0.1 1.0" size="0.015" rgba="0 1 0 1"/>
            <site name="platform_1" pos="-0.1 0.1 1.0" size="0.015" rgba="0 1 0 1"/>
            <site name="platform_2" pos="-0.1 -0.1 1.0" size="0.015" rgba="0 1 0 1"/>
            <site name="platform_3" pos="0.1 -0.1 1.0" size="0.015" rgba="0 1 0 1"/>
        </body>
    </worldbody>

    <tendon>
        <spatial name="cable_0"><site site="anchor_0"/><site site="platform_0"/></spatial>
        <spatial name="cable_1"><site site="anchor_1"/><site site="platform_1"/></spatial>
        <spatial name="cable_2"><site site="anchor_2"/><site site="platform_2"/></spatial>
        <spatial name="cable_3"><site site="anchor_3"/><site site="platform_3"/></spatial>
    </tendon>

    <actuator>
        <motor name="motor_0" tendon="cable_0"/>
        <motor name="motor_1" tendon="cable_1"/>
        <motor name="motor_2" tendon="cable_2"/>
        <motor name="motor_3" tendon="cable_3"/>
    </actuator>
</mujoco>
